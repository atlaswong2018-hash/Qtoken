# AI 社区交流平台 - 生产环境配置
# 复制此文件到 .env.local 并填入实际值

# ===================================
# 数据库配置（必需）
# ===================================

# PostgreSQL 连接字符串
# 格式：postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/your_database

# ===================================
# NextAuth 配置（必需）
# ===================================

# 用于加密 JWT 和会话密钥
# ⚠️ 重要：使用至少 32 个字符的随机字符串
# 可以使用：openssl rand -base64 32
NEXTAUTH_SECRET=your-very-long-random-secret-key-at-least-32-characters-long

# 应用基础 URL（生产环境需要 HTTPS）
NEXTAUTH_URL=https://your-domain.com

# ===================================
# OAuth 提供商（可选）
# ===================================

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===================================
# Telegram Bot 配置（可选）
# ===================================

# Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Channel ID（频道格式：@channel_name，群组格式：-1001234567890）
TELEGRAM_CHANNEL_ID=@your_channel_name

# ===================================
# 文件存储配置（可选）
# ===================================

# AWS S3 配置
S3_BUCKET_NAME=ai-community-platform
S3_ACCESS_KEY=your_aws_access_key
S3_SECRET_KEY=your_aws_secret_key
S3_REGION=us-east-1

# ===================================
# 错误追踪（可选）
# ===================================

# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ===================================
# 应用配置（可选）
# ===================================

# 应用名称
NEXT_PUBLIC_APP_NAME=AI 社区

# 应用 URL（必须包含协议）
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ===================================
# 邮件服务配置（可选）
# ===================================

# SMTP 服务器配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# ===================================
# 性能和监控（可选）
# ===================================

# 启用性能监控
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Sentry 环境
NODE_ENV=production

# ===================================
# 速率限制（可选）
# ===================================

# API 速率限制（每分钟请求数）
RATE_LIMIT_PER_MINUTE=60

# 文件上传限制（MB）
MAX_FILE_UPLOAD_SIZE=10

# ===================================
# 安全配置（可选）
# ===================================

# CORS 允许的源（逗号分隔）
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# 启用 CSP（内容安全策略）
ENABLE_CSP=true

# ===================================
# 功能开关（可选）
# ===================================

# 启用注册（设置为 false 可禁用注册）
ENABLE_REGISTRATION=true

# 启用 Telegram 通知
ENABLE_TELEGRAM_NOTIFICATIONS=true

# 启用 OAuth 登录
ENABLE_OAUTH_LOGIN=true

# ===================================
# 缓存配置（可选）
# ===================================

# Redis 连接字符串（用于缓存）
REDIS_URL=redis://localhost:6379

# 缓存 TTL（秒）
CACHE_TTL=3600

# ===================================
# 日志配置（可选）
# ===================================

# 日志级别（error, warn, info, debug）
LOG_LEVEL=info

# 日志格式（json, text）
LOG_FORMAT=json

# ===================================
# 调试（生产环境应设为 false）
# ===================================

NODE_ENV=production
DEBUG=false
NEXT_PUBLIC_DEBUG=false

# ===================================
# 生成安全的 NEXTAUTH_SECRET
# ===================================
# 使用以下命令生成安全的密钥：
# openssl rand -base64 32
# 或者使用在线工具：https://generate-secret.vercel.app/32

# ===================================
# 安全提示
# ===================================
# ⚠️ 永远不要将 .env.local 文件提交到 Git
# ⚠️ 确保所有密钥都是强随机字符串
# ⚠️ 定期轮换密钥和密码
# ⚠️ 在生产环境中禁用调试模式
