# Database
DATABASE_URL="postgresql://user:password@localhost:5432/discord2"
# 或者使用托管服务：
# DATABASE_URL="postgresql://user:password@ep-soft-white-forest-123456.us-east-1.aws.neon.tech/neondb-123456"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-characters-please-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Telegram Bot（可选）
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHANNEL_ID="@your-channel"

# OAuth（可选）
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# File Storage（可选）
S3_BUCKET_NAME="your-bucket-name"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_REGION="us-east-1"

# Sentry（可选）
NEXT_PUBLIC_SENTRY_DSN="your-sentry-dsn"
